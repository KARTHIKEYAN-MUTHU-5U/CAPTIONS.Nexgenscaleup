# GEMINI_API_KEY: Required for Gemini AI transcription (Best Quality tier).
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required for Groq Whisper transcription (Fast tier).
# Get yours at: https://console.groq.com/keys (free, 2000 requests/day)
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="https://captions.nexgenscaleup.com"
